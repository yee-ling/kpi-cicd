# Keep the build context small and the image clean.
# Generated MLflow state — the build regenerates it (bake) or the registry owns it.
mlflow.db
mlruns/
mlartifacts/

# Python cruft
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/
.env

# Dev / docs / VCS — not needed inside the image
.git/
.gitignore
*.md
docs/
tests/
Dockerfile*
docker-compose.yml
verify.sh
